# Environment Variables for Finora Backend
# Copy this file to .env and fill in your values

# MongoDB Connection String
MONGODB_URI=mongodb://localhost:27017/finora
# Or use MongoDB Atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/finora

# JWT Secret Key (use a long, random string in production)
JWT_SECRET=finora_super_secret_jwt_key_change_in_production_2025

# JWT Expiry Duration
JWT_EXPIRES_IN=7d

# Server Port
PORT=5000

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Node Environment
NODE_ENV=development
